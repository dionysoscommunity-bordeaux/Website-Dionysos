{
    "name": "Website-Dionysos",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "npm run validate:content && nuxt build",
        "dev": "nuxt dev",
        "clean:cache": "rm -rf .nuxt .output",
        "clean:install": "rm -rf node_modules package-lock.json && npm install",
        "dev:clean": "npm run clean:cache && npm run clean:install && npm run dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "validate:content": "node scripts/validate-content.mjs",
        "validate:home-copy": "node scripts/validate-home-copy.mjs",
        "validate:cta-links": "node scripts/validate-cta-links.mjs",
        "validate:legal-pages": "node scripts/validate-legal-pages.mjs",
        "validate:activities-page": "node scripts/validate-activities-page.mjs",
        "validate:activities-gallery": "node scripts/validate-activities-gallery.mjs",
        "validate:social-proof": "node scripts/validate-social-proof.mjs",
        "validate:bordeaux-anchor": "node scripts/validate-bordeaux-anchor.mjs",
        "validate:partners-b2b": "node scripts/validate-partners-b2b.mjs",
        "validate:partner-contact": "node scripts/validate-partner-contact.mjs",
        "validate:seo-tech-foundation": "node scripts/validate-seo-tech-foundation.mjs",
        "validate:social-metadata-schema": "node scripts/validate-social-metadata-schema.mjs",
        "validate:tracking-kpi": "node scripts/validate-tracking-kpi.mjs",
        "validate:pipeline-guards": "node scripts/validate-pipeline-guards.mjs",
        "lint": "npm run validate:content && npm run validate:home-copy && npm run validate:cta-links && npm run validate:legal-pages && npm run validate:activities-page && npm run validate:activities-gallery && npm run validate:social-proof && npm run validate:bordeaux-anchor && npm run validate:partners-b2b && npm run validate:partner-contact && npm run validate:seo-tech-foundation && npm run validate:social-metadata-schema && npm run validate:tracking-kpi && npm run validate:pipeline-guards && eslint .",
        "typecheck": "nuxt prepare && tsc --noEmit -p .nuxt/tsconfig.app.json && tsc --noEmit -p .nuxt/tsconfig.server.json && tsc --noEmit -p .nuxt/tsconfig.shared.json && tsc --noEmit -p .nuxt/tsconfig.node.json"
    },
    "dependencies": {
        "@nuxtjs/plausible": "^3.0.1",
        "@nuxtjs/tailwindcss": "^6.14.0",
        "gray-matter": "^4.0.3",
        "nuxt": "^4.3.1",
        "vue": "^3.5.28",
        "vue-router": "^4.6.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.3.0",
        "eslint": "^10.0.2",
        "globals": "^17.3.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vue-tsc": "^3.2.5"
    }
}